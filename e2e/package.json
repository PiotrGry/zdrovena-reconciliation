{
  "name": "zdrovena-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for zdrovena dashboard",
  "scripts": {
    "test": "playwright test",
    "test:critical": "RUN_FAKE_PROVIDER_E2E=1 playwright test tests/critical-fake-providers.spec.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}

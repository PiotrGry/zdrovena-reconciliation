# zdrovena – local secrets (copy to .env and fill in)
# DO NOT commit .env to git — it is listed in .gitignore

# ── Fakturownia ────────────────────────────────────────────────────────────────
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_LOGIN=
FAKTUROWNIA_PASSWORD=

# ── Zoho Mail ─────────────────────────────────────────────────────────────────
ZOHO_SMTP_PASSWORD=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── KSeF (base64-encoded PEM files) ──────────────────────────────────────────
# Generate with: base64 -i cert.pem | tr -d '\n'
KSEF_CERTIFICATE=
KSEF_PRIVATE_KEY=
KSEF_KEY_PASSWORD=

# ── Google Ads ────────────────────────────────────────────────────────────────
GADS_DEVELOPER_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...         # Admin API access token (custom app)

# IMPORTANT: use "Tajny klucz API" (API secret key, shpss_...) from
# Shopify Admin → Apps → [your app] → API credentials
# NOT the key shown in Settings → Notifications → Webhooks — that one looks
# like a secret but is NOT used for HMAC signing.
SHOPIFY_WEBHOOK_SECRET=shpss_...

# ── InPost ShipX ──────────────────────────────────────────────────────────────
# INPOST_COURIER_SERVICE=inpost_courier_c2c   # sandbox/prepaid: omit on prod

# ── Cloud ─────────────────────────────────────────────────────────────────────
# Azure AD tenant and app registration (non-secret — safe to share within the team)
AZURE_TENANT_ID=a2e78da5-20fe-4ebe-b625-02652d87fda6
AZURE_CLIENT_ID=7a690aca-4a5f-4317-bd89-93b71e0db012
# Local dev: set the vars above + run `az login --tenant $AZURE_TENANT_ID`
# All secrets (Fakturownia, Zoho, KSeF) will be fetched live from AKV — no plaintext needed.
AZURE_KEYVAULT_URL=https://zdrovenakv.vault.azure.net/

# Managed identity (production — already set via Container App env vars)
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
#
# Connection string (Azurite emulator only)
# AZURE_STORAGE_CONNECTION_STRING=
#
# Override default container name (default: zdrovena-files)
# AZURE_STORAGE_CONTAINER=zdrovena-files

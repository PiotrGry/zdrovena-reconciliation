# zdrovena – local secrets (copy to .env and fill in)
# DO NOT commit .env to git — it is listed in .gitignore

# ── Fakturownia ────────────────────────────────────────────────────────────────
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_LOGIN=
FAKTUROWNIA_PASSWORD=

# ── Zoho Mail ─────────────────────────────────────────────────────────────────
ZOHO_SMTP_PASSWORD=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── KSeF (base64-encoded PEM files) ──────────────────────────────────────────
# Generate with: base64 -i cert.pem | tr -d '\n'
KSEF_CERTIFICATE=
KSEF_PRIVATE_KEY=
KSEF_KEY_PASSWORD=

# ── Google Ads ────────────────────────────────────────────────────────────────
GADS_DEVELOPER_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=

# ── Cloud (Faza G — leave empty for local dev) ────────────────────────────────
# AZURE_KEYVAULT_URL=https://<vault-name>.vault.azure.net/
#
# Managed identity (production)
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
#
# Connection string (Azurite emulator only)
# AZURE_STORAGE_CONNECTION_STRING=
#
# Override default container name (default: zdrovena-files)
# AZURE_STORAGE_CONTAINER=zdrovena-files

# Local development environment variables
# Copy to .env.local and fill in real secrets
# .env.local is gitignored — NEVER commit it

# ── Azure Storage — Azurite emulator (docker compose up) ─────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER=zdrovena-files

# ── Skip Azure AD auth locally ────────────────────────────────────────────────
AZURE_AUTH_DISABLED=true
SHOPIFY_WEBHOOK_SECRET=e2e-webhook-secret

# ── Fakturownia (optional — needed for invoice fetching) ─────────────────────
# FAKTUROWNIA_API_TOKEN=
# FAKTUROWNIA_LOGIN=
# FAKTUROWNIA_PASSWORD=

# ── Zoho Mail (optional — needed for close month email) ──────────────────────
# ZOHO_SMTP_PASSWORD=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=

# ── Real Azure (alternative to Azurite — use staging storage account) ────────
# AZURE_STORAGE_ACCOUNT_URL=https://<staging-account>.blob.core.windows.net
# AZURE_STORAGE_CONTAINER=zdrovena-files-staging

# ── SMSAPI.pl (optional — needed for SMS dispatch notifications) ──────────────
# SMSAPI_TOKEN=
# NOTIFY_PHONE=48XXXXXXXXX   # operator phone for new-order SMS alerts

# ── Shopify Admin API ─────────────────────────────────────────────────────────
# SHOPIFY_ACCESS_TOKEN=       # shpat_... from Shopify Partners / store admin
# SHOPIFY_SHOP_DOMAIN=        # <nazwa>.myshopify.com
# SHOPIFY_WEBHOOK_SECRET=     # API secret key — dev: zostaw zakomentowane (HMAC pomijany); prod: Key Vault

# ── InPost ShipX ──────────────────────────────────────────────────────────────
# INPOST_API_TOKEN=           # JWT from InPost panel (sandbox or prod)
# INPOST_ORGANIZATION_ID=     # numeric org ID from InPost panel
# INPOST_BASE_URL=https://sandbox-api-shipx-pl.easypack24.net  # omit for prod


# Smoke test secrets — copy to .env.smoke and fill in values.
# .env.smoke is gitignored — never commit real secrets.
#
# Get these values from:
#   AZURE_TENANT_ID       — az account show --query tenantId -o tsv
#   AZURE_API_CLIENT_ID   — az ad app list --display-name zdrovena-api --query [0].appId -o tsv
#   SMOKE_SP_*            — from your password manager (set during initial setup)

AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=

# zdrovena-smoke-tester SP (viewer role)
SMOKE_SP_CLIENT_ID=
SMOKE_SP_CLIENT_SECRET=

# zdrovena-smoke-accountant SP (accountant role)
SMOKE_ACCOUNTANT_SP_CLIENT_ID=
SMOKE_ACCOUNTANT_SP_CLIENT_SECRET=

# Optional — auto-detected from Azure if not set
# API_URL=https://zdrovena-api-staging.xxx.azurecontainerapps.io
# SWA_URL=https://xxx.azurestaticapps.net
